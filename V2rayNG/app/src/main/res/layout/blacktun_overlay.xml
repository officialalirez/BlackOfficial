<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/blacktun_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_blacktun_main"
    android:visibility="gone">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/blacktun_header_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_spacing_dp16"
        android:layout_marginTop="@dimen/padding_spacing_dp16"
        android:layout_marginEnd="@dimen/padding_spacing_dp16"
        app:cardBackgroundColor="#0B1220"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="#1E3A5F"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/padding_spacing_dp16">

            <TextView
                android:id="@+id/blacktun_brand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/blacktun_app_title"
                android:textColor="@color/colorWhite"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/blacktun_source_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_blacktun_chip"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingTop="7dp"
                android:paddingEnd="12dp"
                android:paddingBottom="7dp"
                android:text="@string/blacktun_not_logged_in"
                android:textColor="@color/colorWhite"
                android:textSize="12sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/blacktun_connect_card"
        android:layout_width="210dp"
        android:layout_height="210dp"
        app:cardBackgroundColor="#07101C"
        app:cardCornerRadius="120dp"
        app:cardElevation="24dp"
        app:strokeColor="#1E88FF"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toTopOf="@id/blacktun_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/blacktun_header_card"
        app:layout_constraintVertical_chainStyle="packed">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/blacktun_connect_button"
            android:layout_width="168dp"
            android:layout_height="168dp"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:text="@string/blacktun_connect"
            android:textColor="@color/colorWhite"
            android:textSize="22sp"
            app:backgroundTint="@color/blacktun_blue"
            app:cornerRadius="999dp"
            app:rippleColor="#64B5FF" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/blacktun_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="36dp"
        android:gravity="center"
        android:text="@string/blacktun_ready"
        android:textColor="@color/colorWhite"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/blacktun_connect_card" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/blacktun_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="56dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/blacktun_blue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/blacktun_status"
        app:trackColor="#182335" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/blacktun_selector_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="24dp"
        android:visibility="visible"
        app:cardBackgroundColor="#0B1220"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="#1E3A5F"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/blacktun_progress">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="انتخاب کانفیگ"
                android:textColor="@color/colorWhite"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/blacktun_auto_select_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="انتخاب خودکار 🚀"
                android:textColor="@color/colorWhite"
                android:textSize="14sp"
                app:backgroundTint="#10213A"
                app:cornerRadius="16dp"
                app:rippleColor="#64B5FF"
                app:strokeColor="#1E88FF"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/blacktun_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="24dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/blacktun_selector_card">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/blacktun_subscription_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="ورود به اشتراک"
            android:textColor="@color/colorWhite"
            android:textSize="14sp"
            app:backgroundTint="#10213A"
            app:cornerRadius="18dp"
            app:rippleColor="#1E88FF"
            app:strokeColor="#1E88FF"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/blacktun_free_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="🎁 ورود رایگان"
            android:textColor="@color/colorWhite"
            android:textSize="14sp"
            app:backgroundTint="#122015"
            app:cornerRadius="18dp"
            app:rippleColor="#35D07F"
            app:strokeColor="#35D07F"
            app:strokeWidth="1dp" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/blacktun_message_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="#0B1220"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="#1E3A5F"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/blacktun_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="14dp"
            android:textColor="@color/blacktun_success"
            android:textSize="14sp" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
